# Copy to `.env` in this directory (`.env` is gitignored).
# Vite inlines `VITE_*` variables when you run `pnpm build` — changing them requires a rebuild.
#
# GlitchTip → Project → Client Keys (DSN). Still required when using the ingest tunnel (metadata + envelope).
# Example:
#   https://PUBLIC_KEY@glitchtip-my-first-lamp-app.lndo.site/PROJECT_ID
#
# Browser SDK defaults to POSTing envelopes via CodeIgniter → GlitchTip on Docker (`/learning/elk/glitchtip-tunnel`).
# To send directly to GlitchTip instead (no PHP proxy), set:
#   VITE_GLITCHTIP_TUNNEL_PATH=
VITE_GLITCHTIP_DSN=

# Optional — override tunnel path (default `/learning/elk/glitchtip-tunnel`). Empty string disables tunneling.
# VITE_GLITCHTIP_TUNNEL_PATH=

# Optional — align with SENTRY_RELEASE when using @sentry/vite-plugin for source maps
# VITE_GLITCHTIP_RELEASE=local-dev

# Optional — performance sample rate 0–1 (defaults: 0 in dev, 0.01 in production build)
# VITE_GLITCHTIP_TRACES_SAMPLE_RATE=0

# --- Backend GlitchTip ingest proxy (appserver → glitchtip container on Lando network)
# glitchtip.internalIngestBase=http://glitchtip:8000
# glitchtip.allowedProjectIds=1
# glitchtip.allowedDsnHosts=glitchtip-my-first-lamp-app.lndo.site
