{
  "name": "codeigniter-tutorial-frontend",
  "private": true,
  "packageManager": "pnpm@10.10.0",
  "scripts": {
    "build": "vite build",
    "build:cssmap": "VITE_FULL_CSS_MAP=1 vite build",
    "watch": "VITE_FULL_CSS_MAP=1 vite build --watch",
    "watch:fast": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint resources",
    "lint:css": "stylelint \"resources/**/*.scss\"",
    "lint:css:fix": "stylelint \"resources/**/*.scss\" --fix",
    "lint:all": "pnpm lint && pnpm lint:css",
    "format": "oxfmt resources",
    "format:check": "oxfmt --check resources",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "bash -c 'if [ -z \"${PLAYWRIGHT_BASE_URL-}\" ]; then export PLAYWRIGHT_BASE_URL=\"https://my-first-lamp-app.lndo.site\"; export PLAYWRIGHT_IGNORE_HTTPS_ERRORS=1; fi; exec playwright test'",
    "test:e2e:lando:http": "PLAYWRIGHT_BASE_URL=http://my-first-lamp-app.lndo.site playwright test",
    "test:e2e:lando:https": "PLAYWRIGHT_BASE_URL=https://my-first-lamp-app.lndo.site PLAYWRIGHT_IGNORE_HTTPS_ERRORS=1 playwright test",
    "test:e2e:spark": "playwright test",
    "test:e2e:queue-tasks": "playwright test tests/e2e/queue_tasks_integration.spec.ts",
    "deploy:local:up": "make deploy-local-up",
    "deploy:local:wait": "make deploy-local-wait-ssh",
    "deploy:local:down": "make deploy-local-down",
    "deploy:local:fetch": "make deploy-local-fetch-artifact",
    "deploy:local:deploy:url": "make deploy-local-deploy-url",
    "deploy:local:deploy:file": "make deploy-local-deploy-file",
    "deploy:local:demo": "make deploy-local-demo",
    "deploy:local:demo:built": "make deploy-local-demo-built",
    "deploy:local:build:release-ci": "make deploy-local-build-release-ci",
    "deploy:local:demo:ci": "make deploy-local-demo-ci",
    "deploy:local:migrate": "make deploy-local-migrate"
  },
  "devDependencies": {
    "@playwright/test": "latest",
    "@types/backbone": "^1.4.23",
    "@types/jquery": "^4.0.0",
    "@types/node": "^25.6.0",
    "@types/underscore": "^1.13.0",
    "happy-dom": "^20.9.0",
    "oxfmt": "latest",
    "oxlint": "latest",
    "sass": "latest",
    "stylelint": "^17.9.1",
    "stylelint-config-standard-scss": "^17.0.0",
    "typescript": "latest",
    "vite": "latest",
    "vitest": "latest"
  },
  "dependencies": {
    "backbone": "^1.6.1",
    "jquery": "^4.0.0",
    "underscore": "^1.13.8"
  }
}
