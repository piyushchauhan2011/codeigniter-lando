/.env
/vendor/
/build/
/node_modules/
/dist/
/public/assets/dist/
/playwright-report/
/test-results/

# OS/editor noise
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/

# Runtime/generated content
/writable/cache/*
/writable/session/*
/writable/debugbar/*
/writable/logs/*
/writable/uploads/*

# Keep writable subdirectories
!/writable/cache/index.html
!/writable/session/index.html
!/writable/debugbar/index.html
!/writable/logs/index.html
!/writable/uploads/index.html

# PHPUnit (optional local cache; never commit)
.phpunit.result.cache
