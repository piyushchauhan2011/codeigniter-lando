# Copy to shared.env (gitignored): cp shared.env.example shared.env
# Job portal routes need MySQL — compose starts mysql automatically (hostname `mysql` from PHP).

CI_ENVIRONMENT = development

app.baseURL = 'http://127.0.0.1:9080/'
app.forceGlobalSecureRequests = false

# Empty = omit index.php from site_url()/portal_url(); Apache rewrite sends URIs to index.php anyway.
app.indexPage =

# Generate once: lando php spark key:generate   OR   php spark key:generate
encryption.key = hex2bin:d17300526948fcbfbcd463f091647cf91482f933dbf804cfbde469bbe50bcd73

database.default.hostname = mysql
database.default.database = ci4
database.default.username = lamp
database.default.password = lamp
database.default.DBDriver = MySQLi
database.default.port = 3306
